generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Book {
  id        String   @id @default(cuid())
  title     String
  author    String
  isbn      String   @unique
  pages     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
